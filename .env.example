APP_NAME=docustruct-ai
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

DATABASE_URL=postgresql+psycopg://docustruct:docustruct@postgres:5432/docustruct
REDIS_URL=redis://redis:6379/0

STORAGE_ROOT=./data/storage
ARTIFACTS_ROOT=./data/artifacts
TEMPLATES_DIR=./src/docustruct_ai/templates

EXECUTION_MODE=inline
ACCEPT_THRESHOLD=0.85
REVIEW_THRESHOLD=0.55
REJECT_THRESHOLD=0.25
